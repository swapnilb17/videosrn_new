# OpenAI (required for script generation)
OPENAI_API_KEY=
# e.g. gpt-5, gpt-5-mini, gpt-4o
OPENAI_MODEL=gpt-5

# Google Cloud Text-to-Speech (preferred when configured — stable Devanagari / mixed hi/mr + Latin).
# Service account needs roles/cloudtexttospeech.user; enable Cloud Text-to-Speech API on the project.
#
# Option A — JSON key file (typical for EC2: deploy the file and point to it):
GOOGLE_TTS_CREDENTIALS_JSON=
# Option B — standard env (same as many GCP tools):
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
#
# Option C — no JSON on disk: VM/instance has an attached GCP service account (GCE, GKE, or federated AWS).
# Set true so the app uses Application Default Credentials for TTS (still enable Cloud TTS API on that identity).
GOOGLE_TTS_USE_ADC=false
#
# Optional: pin a voice (else auto-pick Neural2/Chirp from list_voices). Examples:
# GOOGLE_TTS_VOICE_MR=mr-IN-Neural2-A
# GOOGLE_TTS_VOICE_HI=hi-IN-Neural2-A
GOOGLE_TTS_VOICE_EN=
GOOGLE_TTS_VOICE_HI=
GOOGLE_TTS_VOICE_MR=
# Per-request byte budget for input text (API limit ~5000; default leaves margin).
GOOGLE_TTS_MAX_INPUT_BYTES=4500
GOOGLE_TTS_SPEAKING_RATE=1.0
# Semitones roughly -20..20
GOOGLE_TTS_PITCH=0.0

# ElevenLabs — used when Google Cloud TTS is not configured; otherwise optional fallback path is Coqui only.
ELEVENLABS_API_KEY=
# Default voice if language-specific voices are unset (from ElevenLabs voice library)
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_EN=
ELEVENLABS_VOICE_HI=
ELEVENLABS_VOICE_MR=
# Optional; multilingual model default
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Artifacts (temp job dirs; on EC2 use e.g. /var/lib/avatar/jobs)
ARTIFACT_ROOT=./data/jobs

# --- Optional: PostgreSQL + S3 (set all three to enable; leave empty for local disk only) ---
# Async URL for SQLAlchemy + asyncpg:
# DATABASE_URL=postgresql+asyncpg://avatar_app:PASSWORD@127.0.0.1:5432/avatar
DATABASE_URL=
# Bucket name only (e.g. videosrv), not a URL — use S3_ENDPOINT_URL for MinIO etc.
S3_BUCKET=
S3_REGION=
# Object key prefix (default jobs/). IAM policy should allow this prefix.
S3_PREFIX=jobs/
# S3-compatible endpoint (MinIO etc.); leave empty for AWS.
S3_ENDPOINT_URL=
# Presigned GET lifetime for /media redirects (seconds).
MEDIA_PRESIGN_EXPIRES_SECONDS=3600
# Local AWS profile (dev); on EC2 prefer IAM instance role and leave empty.
AWS_PROFILE=
# Remove local job dir after successful S3 upload (saves EBS).
ARTIFACT_CLEANUP_AFTER_S3=true

# Video frame size (vertical Shorts/Reels default)
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920

# HTTP timeouts (seconds)
OPENAI_TIMEOUT=120
ELEVENLABS_TIMEOUT=120

# MP4 mux + Coqui MP3 encoding need ffmpeg. Options:
# - Put a binary in the project folder as ./ffmpeg (or ./bin/ffmpeg) — auto-detected
# - Or set an explicit path (relative paths are from the project root):
#   FFMPEG_PATH=./ffmpeg
#   FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
FFMPEG_PATH=

# Coqui fallback (optional): pip install -e ".[coqui]"
COQUI_MODEL_EN=tts_models/en/ljspeech/tacotron2-DDC
COQUI_MODEL_HI=tts_models/hi/cv/vits
COQUI_MODEL_MR=tts_models/hi/cv/vits

# --- Imagen slide images (choose ONE primary path) ---
# A) Vertex AI Imagen (GCP: enable Vertex AI API, billing, service account with Vertex AI User on the project).
#    Uses same JSON as TTS: GOOGLE_TTS_CREDENTIALS_JSON or GOOGLE_APPLICATION_CREDENTIALS.
IMAGEN_USE_VERTEX=false
VERTEX_IMAGEN_PROJECT=
# Comma-separated regions (order = try order for failover). Default single region Iowa:
VERTEX_IMAGEN_REGIONS=us-central1
# Also accepted: GOOGLE_CLOUD_PROJECT as alias for VERTEX_IMAGEN_PROJECT.
#
# Veo video (image/text → video) — same service account + project as Vertex Imagen.
# Model examples: veo-3.0-generate-001, veo-3.1-generate-001, veo-3.1-fast-generate-001
VERTEX_VEO_MODEL=veo-3.0-generate-001
# GCS prefix for Vertex Veo output (defaults to gs://veo_enablyai/; override for other GCP projects). Use gs:// not console URLs.
VERTEX_VEO_STORAGE_URI=gs://veo_enablyai/

# When S3_BUCKET + S3_REGION are set, finished Veo MP4s are also uploaded under {S3_PREFIX}veo3/...
# (same bucket as main jobs). ARTIFACT_CLEANUP_AFTER_S3 removes the local copy after upload.
# B) Google AI Studio (API key) — used when IMAGEN_USE_VERTEX=false
# https://aistudio.google.com/app/apikey — GOOGLE_API_KEY aliases GEMINI_API_KEY.
GEMINI_API_KEY=
# Nano Banana 2 (Gemini native image) is tried first when GEMINI_API_KEY is set. Falls back to Imagen on failure.
GEMINI_NATIVE_IMAGE_FIRST=true
GEMINI_NATIVE_IMAGE_MODEL=gemini-3.1-flash-image-preview
# Faster wall-clock; for maximum quality use imagen-4.0-generate-001 (standard).
IMAGEN_MODEL=imagen-4.0-fast-generate-001
# If IMAGEN_MODEL is the standard imagen-4.0-generate-001, the app remaps to fast unless you set:
# IMAGEN_ALLOW_STANDARD_GENERATE=true
IMAGEN_ALLOW_STANDARD_GENERATE=false
# 1K or 2K (Ultra/Standard/Fast models)
IMAGEN_IMAGE_SIZE=1K
# 1:1, 3:4, 4:3, 9:16, 16:9 — vertical video default:
IMAGEN_ASPECT_RATIO=9:16
# dont_allow | allow_adult | allow_all (region restrictions apply — see Google docs)
IMAGEN_PERSON_GENERATION=allow_adult
GEMINI_TIMEOUT=180
# Use 1 if you see flaky slides (rate limits / empty Imagen responses).
IMAGEN_MAX_CONCURRENT=1
# Optional: loosen safety if Vertex returns empty predictions for anatomy/health topics (see Google Imagen docs).
# Example: block_only_high
IMAGEN_SAFETY_SETTING=

# Third-party Nano Banana-style API (last resort) — after Gemini native image + Imagen if both fail or are disabled.
# If your dashboard uses a different host, set the base URL (no trailing slash).
NANO_BANANA_API_KEY=
NANO_BANANA_BASE_URL=https://api.nanobananaimages.com
NANO_BANANA_STYLE=cinematic
NANO_BANANA_STEPS=25
NANO_BANANA_GUIDANCE=7.5
NANO_BANANA_TIMEOUT=180
NANO_BANANA_MAX_CONCURRENT=2

# --- Optional: Google OAuth (sign-in). Set all four to require Google before POST /generate. ---
# Step-by-step: docs/GOOGLE_OAUTH.md
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client (Web application):
#   Authorized JavaScript origin: https://YOUR_DOMAIN (no path)
#   Authorized redirect URI must match exactly: https://YOUR_DOMAIN/auth/google/callback
# SESSION_SECRET: long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
# Aliases: GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GOOGLE_REDIRECT_URI
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
# Set false behind local HTTP; use true in production (HTTPS). Behind nginx TLS, enable proxy headers
# on uvicorn so the app sees https:// (e.g. uvicorn ... --proxy-headers).
SESSION_COOKIE_SECURE=true

# --- Security / operations (optional) ---
# Expose database_error_type on /health (default false — avoids leaking exception class names).
HEALTH_EXPOSE_INTERNALS=false
# OpenAPI /docs and /openapi.json (set false in production if you do not want schema discovery).
OPENAPI_ENABLED=true
# POST /generate per-IP limit (slowapi). Use off, false, none, or 0 to disable (very high cap).
RATE_LIMIT_GENERATE=12/minute
# Per-IP limit for GET /api/tts/preview.mp3 (Google TTS samples). off / false / none / 0 disables.
RATE_LIMIT_TTS_PREVIEW=30/minute
