# EnablyAI VGEN — example environment for Docker Compose (repo root)
# Copy to .env and fill in values:  cp .env.example .env
# docker-compose.yml loads this file as env_file for the backend container.

# --- Kling AI (Image to Video / Text to Video, when user selects Kling in the UI) ---
# Use ONE authentication method:
#   • KLING_API_KEY only — Bearer token (typical for gateways; default API host api.klingapi.com)
#   • KLING_ACCESS_KEY + KLING_SECRET_KEY — official-style JWT (default host api.klingai.com)
# Leave the unused method empty. After editing, restart backend: docker compose up -d --force-recreate backend
KLING_API_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
# KLING_BASE_URL=
KLING_MODEL=kling-v2-5-turbo
KLING_MODE=pro
# KLING_POLL_INTERVAL_SEC=8
# KLING_MAX_POLL_ATTEMPTS=90
# KLING_HTTP_TIMEOUT=120
# KLING_JWT_TTL_SEC=1800

# For a full stack template (Postgres, Vertex, OAuth, etc.), see .env.docker.example
