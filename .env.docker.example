# =====================================================
# EnablyAI VGEN — Docker Environment Variables
# Copy to .env and fill in your real values
# =====================================================

# --- PostgreSQL (managed by Docker Compose) ---
POSTGRES_USER=avatar_app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=avatar
# DATABASE_URL is auto-set in docker-compose.yml — no need to set here

# --- OpenAI (required for script generation) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_TIMEOUT=120

# --- Google Cloud Text-to-Speech ---
# The JSON key file is mounted at /secrets/gcp/service-account.json (see docker-compose.yml).
# Place your service account JSON in ./gcp-credentials/service-account.json
GOOGLE_TTS_CREDENTIALS_JSON=/secrets/gcp/service-account.json
GOOGLE_TTS_USE_ADC=false
GOOGLE_TTS_VOICE_EN=
GOOGLE_TTS_VOICE_HI=
GOOGLE_TTS_VOICE_MR=
GOOGLE_TTS_MAX_INPUT_BYTES=4500
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_PITCH=0.0

# --- ElevenLabs (optional fallback) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_EN=
ELEVENLABS_VOICE_HI=
ELEVENLABS_VOICE_MR=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_TIMEOUT=120

# --- Artifacts ---
ARTIFACT_ROOT=/data/jobs
ARTIFACT_CLEANUP_AFTER_S3=true

# --- S3 (required for persistence) ---
S3_BUCKET=
S3_REGION=
S3_PREFIX=jobs/
S3_ENDPOINT_URL=
MEDIA_PRESIGN_EXPIRES_SECONDS=3600
AWS_PROFILE=

# --- Video defaults ---
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920

# --- ffmpeg (auto-detected in Docker) ---
FFMPEG_PATH=/usr/bin/ffmpeg

# --- Imagen / Gemini (slide image generation) ---
GEMINI_API_KEY=
GEMINI_NATIVE_IMAGE_FIRST=true
GEMINI_NATIVE_IMAGE_MODEL=gemini-3.1-flash-image-preview
IMAGEN_MODEL=imagen-4.0-fast-generate-001
IMAGEN_ALLOW_STANDARD_GENERATE=false
IMAGEN_IMAGE_SIZE=1K
IMAGEN_ASPECT_RATIO=9:16
IMAGEN_PERSON_GENERATION=allow_adult
IMAGEN_SAFETY_SETTING=
GEMINI_TIMEOUT=180
IMAGEN_MAX_CONCURRENT=1

# --- Vertex AI Imagen (GCP service account; default on) ---
# Set false only if you use Generative Language Imagen with GEMINI_API_KEY (no Vertex).
IMAGEN_USE_VERTEX=true
VERTEX_IMAGEN_PROJECT=
VERTEX_IMAGEN_REGIONS=us-central1
VERTEX_VEO_MODEL=veo-3.1-lite-generate-001
# GCS output for Vertex Veo (e.g. gs://veo_enablyai/ — see Cloud Console bucket browser)
VERTEX_VEO_STORAGE_URI=gs://veo_enablyai/
# allow_adult | allow_all | disallow — 17301594 may need allow_all + policy/allowlist
VERTEX_VEO_PERSON_GENERATION=allow_adult

# --- Vertex Gemini Image failover ---
VERTEX_GEMINI_IMAGE_FAILOVER=true
VERTEX_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
VERTEX_GEMINI_IMAGE_REGIONS=

# --- Nano Banana (third-party fallback) ---
NANO_BANANA_API_KEY=
NANO_BANANA_BASE_URL=https://api.nanobananaimages.com
NANO_BANANA_STYLE=cinematic
NANO_BANANA_STEPS=25
NANO_BANANA_GUIDANCE=7.5
NANO_BANANA_TIMEOUT=180
NANO_BANANA_MAX_CONCURRENT=2

# --- Google OAuth (sign-in) ---
# Generate SESSION_SECRET with: openssl rand -hex 32
SESSION_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must match Google Console redirect URI: https://app.yourdomain.com/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=
SESSION_COOKIE_SECURE=true

# --- Next.js / NextAuth (frontend container reads this .env via docker-compose) ---
# Public URL of the site (no trailing slash). Required for OAuth callback in production.
NEXTAUTH_URL=https://ai.enablyai.com
# Optional alias of SESSION_SECRET; lib/auth.ts accepts either.
# NEXTAUTH_SECRET=

# --- Security / Operations ---
HEALTH_EXPOSE_INTERNALS=false
OPENAPI_ENABLED=true
RATE_LIMIT_GENERATE=12/minute
RATE_LIMIT_TTS_PREVIEW=30/minute
